# Platform Secret Key for Signature Verification
# Generate a secure random key using: python -c "import secrets; print(secrets.token_hex(32))"
# This key is used for HMAC-SHA256 platform signature generation and verification
PLATFORM_SECRET_KEY=your_secure_64_character_hex_key_here_replace_this

# Application Settings
APP_NAME=SecureStego
APP_VERSION=1.0.0
DEBUG=False

# API Settings
API_PREFIX=/api
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Argon2id Parameters (OWASP Recommended)
# Time cost: Number of iterations
ARGON2_TIME_COST=3
# Memory cost: Memory in KiB (65536 = 64 MB)
ARGON2_MEMORY_COST=65536
# Parallelism: Number of parallel threads
ARGON2_PARALLELISM=4
# Hash length: Output hash length in bytes (32 = 256 bits for AES-256)
ARGON2_HASH_LEN=32
# Salt length: Salt length in bytes (16 = 128 bits)
ARGON2_SALT_LEN=16

# File Upload Limits (in MB)
MAX_FILE_SIZE_MB=100
MAX_IMAGE_SIZE_MB=50
MAX_VIDEO_SIZE_MB=500
MAX_AUDIO_SIZE_MB=100
MAX_DOCUMENT_SIZE_MB=50

# Logging Settings
LOG_LEVEL=INFO
# LOG_FILE=logs/app.log  # Uncomment to enable file logging, leave empty for stdout only

# Storage Settings
# TEMP_DIR=/tmp/securestego  # Uncomment to use custom temp directory, leave empty for system default
